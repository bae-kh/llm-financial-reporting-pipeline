# ==============================================================
# .env.example — LLM 기반 금융 데이터 리포팅 파이프라인 환경 변수 템플릿
# ==============================================================
# 사용법: 이 파일을 복사하여 .env로 이름을 변경한 후, 실제 값을 입력하세요.
#   cp .env.example .env
#
# ⚠️ 주의: .env 파일은 절대 Git에 커밋하지 마세요!
# ==============================================================

# --- OpenAI / LLM 설정 ---
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_API_KEY_HERE"
USE_LOCAL_LLM="False"
# USE_LOCAL_LLM="True"로 설정 시 Ollama 로컬 서버(localhost:11434) 사용

# --- 시장 데이터 ---
FINNHUB_API_KEY="YOUR_FINNHUB_API_KEY_HERE"

# --- 한국투자증권(KIS) API ---
KIS_APP_KEY=YOUR_KIS_APP_KEY_HERE
KIS_APP_SECRET=YOUR_KIS_APP_SECRET_HERE
KIS_ACCOUNT_NO=12345678-01
# 환경 설정: "virtual" (모의투자) 또는 "production" (실전)
KIS_ENVIRONMENT="virtual"

# --- 텔레그램 알림 ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
